{
  "name": "@velajs/errors",
  "version": "1.1.0",
  "description": "Unified error layer for Vela: branded VelaError, composable error catalogs, and the single toErrorBody wire-redaction seam",
  "keywords": [
    "error-catalog",
    "errors",
    "framework",
    "redaction",
    "vela"
  ],
  "homepage": "https://github.com/velajs/errors#readme",
  "bugs": {
    "url": "https://github.com/velajs/errors/issues"
  },
  "license": "MIT",
  "author": "ksh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velajs/errors.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fingerprint": {
      "types": "./dist/fingerprint.d.ts",
      "import": "./dist/fingerprint.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "verify": "pnpm lint && pnpm format:check && pnpm build && pnpm typecheck && pnpm test && pnpm publint && pnpm attw"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@changesets/cli": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.11.0"
}
