{
  "name": "@velajs/errors",
  "version": "1.0.0",
  "description": "Unified error layer for Vela: branded VelaError, composable error catalogs, and the single toErrorBody wire-redaction seam",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rm -rf dist && swc src -d dist --strip-leading-paths && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "prepare": "swc src -d dist --strip-leading-paths && tsc --emitDeclarationOnly",
    "prepublishOnly": "pnpm run typecheck && pnpm test"
  },
  "sideEffects": false,
  "keywords": [
    "vela",
    "errors",
    "error-catalog",
    "redaction",
    "framework"
  ],
  "author": "ksh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velajs/errors.git"
  },
  "homepage": "https://github.com/velajs/errors#readme",
  "bugs": {
    "url": "https://github.com/velajs/errors/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
}
